<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.EventsHomeFragment"
    android:paddingHorizontal="16dp"
    android:orientation="vertical">

<!--    HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp"
            tools:layout_editor_absoluteX="16dp" />
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:text="Your Events"
            android:textSize="24dp"
            tools:layout_editor_absoluteX="16dp" />
    </LinearLayout>

<!--    CATEGORY TABS -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/events_home_tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.tabs.TabItem
            android:id="@+id/entered_events_tab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entered">
        </com.google.android.material.tabs.TabItem>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/hosted_events_tab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hosting"/>
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/event_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>







