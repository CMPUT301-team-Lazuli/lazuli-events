<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_view_edit_event"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4FA"
    android:fillViewport="true"
    tools:context=".home.TabViewEditEventFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <!-- View Event card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_view_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#DCE4F7"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#DCE4F7"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="58dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_icon_chip"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/icon_view_event"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="View event"
                        android:src="@drawable/ic_view_event"
                        app:tint="#C8C1CC" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_view_event"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="View Event"
                    android:textColor="#1F1F1F"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/icon_view_event_arrow"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Go"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#1F1F1F" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Edit Event card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_edit_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#F1D8B6"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#F1D8B6"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="58dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_icon_chip"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/icon_edit_event"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Edit event"
                        android:src="@drawable/ic_edit_event"
                        app:tint="#C8C1CC" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_edit_event"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Edit Event"
                    android:textColor="#1F1F1F"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- View Map card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_view_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#CFE1AF"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#CFE1AF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="58dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_icon_chip"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/icon_view_map"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="View map"
                        android:src="@drawable/ic_view_map"
                        app:tint="#C8C1CC" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_view_map"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="View Map"
                    android:textColor="#1F1F1F"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/icon_view_map_arrow"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Go to map"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#1F1F1F" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Entrant geolocation -->
        <LinearLayout
            android:id="@+id/row_geolocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_geolocation_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Entrant geolocation required"
                android:textColor="#3F3A43"
                android:textSize="12sp" />

            <CheckBox
                android:id="@+id/cb_geolocation_required"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#7B5FCB"
                android:checked="true" />
        </LinearLayout>

        <!-- QR row -->
        <LinearLayout
            android:id="@+id/row_qr"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#F7F4FA"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:id="@+id/icon_qr"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="QR code"
                android:src="@drawable/ic_qr_code"
                app:tint="#1F1F1F" />

            <TextView
                android:id="@+id/tv_qr_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="[Generate or View] QR code"
                android:textColor="#1F1F1F"
                android:textSize="15sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D8D1DB" />

        <!-- CSV row -->
        <LinearLayout
            android:id="@+id/row_csv"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#F7F4FA"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:id="@+id/icon_csv"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="CSV"
                android:src="@drawable/ic_download_csv"
                app:tint="#1F1F1F" />

            <TextView
                android:id="@+id/tv_csv_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Download CSV files"
                android:textColor="#1F1F1F"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/icon_csv_download"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Download"
                android:src="@drawable/ic_download"
                app:tint="#1F1F1F" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D8D1DB" />

        <!-- Cancel button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_event"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:text="Cancel Event"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:backgroundTint="#E4664E"
            app:cornerRadius="26dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>